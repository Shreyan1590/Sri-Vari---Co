{
  "name": "sri-vari-backend",
  "version": "1.0.0",
  "description": "Backend API for Sri Vari & Co Mobile Shop Management",
  "main": "src/index.js",
  "scripts": {
    "start": "node node_modules/wrangler/bin/wrangler.js dev",
    "login": "node node_modules/wrangler/bin/wrangler.js login",
    "deploy": "node node_modules/wrangler/bin/wrangler.js deploy",
    "db:init": "node node_modules/wrangler/bin/wrangler.js d1 execute DB --local --file=schema.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "wrangler": "^4.65.0"
  }
}
