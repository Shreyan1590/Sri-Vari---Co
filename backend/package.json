{
  "name": "sri-vari-backend",
  "version": "1.0.0",
  "description": "Backend API for Sri Vari & Co Mobile Shop Management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "wrangler:dev": "node node_modules/wrangler/bin/wrangler.js dev",
    "login": "node node_modules/wrangler/bin/wrangler.js login",
    "deploy": "node node_modules/wrangler/bin/wrangler.js deploy",
    "db:init": "node node_modules/wrangler/bin/wrangler.js d1 execute DB --local --file=schema.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "wrangler": "^4.65.0"
  }
}
